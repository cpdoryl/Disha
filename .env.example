# Database
DATABASE_URL=postgresql://disha_user:disha_password@localhost:5432/disha_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=disha_user
DATABASE_PASSWORD=change_me_in_production
DATABASE_NAME=disha_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=900s
REFRESH_TOKEN_EXPIRES_IN=604800s

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=disha-documents-dev
AWS_ACCOUNT_ID=123456789012

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=razorpay_key_id
RAZORPAY_KEY_SECRET=razorpay_key_secret

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# Mail Service (Optional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Slack (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Environment
NODE_ENV=development
ENVIRONMENT=development
LOG_LEVEL=debug
PORT=3000

# Frontend URLs
NEXT_PUBLIC_API_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:3000

# Mobile API Base URL
REACT_NATIVE_API_URL=http://localhost:3000

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_SENTRY=true
ENABLE_COMPETITOR_BENCHMARKING=true
ENABLE_CONTINUOUS_REDIAGNOSIS=false

# Data Retention (Days)
DATA_RETENTION_DOCUMENTS=30
DATA_RETENTION_ASSESSMENTS=365
DATA_RETENTION_REPORTS=forever
DATA_RETENTION_WELLBEING=1825

# SonarCloud (Optional)
SONARCLOUD_TOKEN=your_sonarcloud_token
SONARCLOUD_PROJECT_KEY=your_project_key

# Sentry (Optional)
SENTRY_DSN=https://xxxxx@o000.ingest.sentry.io/000000
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
